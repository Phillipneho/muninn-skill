# Muninn Memory System Configuration
# 
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# =============================================================================
# EMBEDDING MODE (required)
# =============================================================================
# Choose: ollama (local, free) or openai (cloud, paid)

EMBEDDING_MODE=ollama

# =============================================================================
# OPENAI API KEY (required if EMBEDDING_MODE=openai)
# =============================================================================
# Get your key at: https://platform.openai.com/api-keys
# Format: sk-proj-...

OPENAI_API_KEY=sk-proj-your-openai-api-key-here

# =============================================================================
# DATABASE PATH (optional)
# =============================================================================
# Local SQLite database location. Defaults to ~/.openclaw/muninn-memories.db

# DATABASE_PATH=/path/to/your/database.db

# =============================================================================
# MCP SERVER (advanced)
# =============================================================================
# MCP uses stdin/stdout for communication. No network configuration needed.

# MCP_SERVER_PORT=stdio